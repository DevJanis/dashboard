---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
let overview = null, insights = null;
try {
  const r1 = await fetch(base + 'data/derived/overview.json').catch(()=>null);
  if(r1?.ok) overview = await r1.json();
  const r2 = await fetch(base + 'data/derived/insights.json').catch(()=>null);
  if(r2?.ok) insights = await r2.json();
} catch {}
---
<Base title="Overview">
  <h1>Overview</h1>
  {overview ? (
    <div class="card">
      <p><strong>Status:</strong> {overview.status}</p>
      {overview.highlights?.map(h => <p class="placeholder">{h}</p>)}
    </div>
  ) : (
    <div class="card"><p class="placeholder">overview.json not yet available.</p></div>
  )}
  {insights && (
    <div class="card">
      <h2>Insights</h2>
      {insights.training?.map(t => <p>Training: {t}</p>)}
      {insights.recovery?.map(r => <p>Recovery: {r}</p>)}
    </div>
  )}
</Base>
