---
export interface Props { title: string; }
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Janis Dashboard</title>
    <style>
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      body{font-family:system-ui,sans-serif;background:#0f172a;color:#e2e8f0;min-height:100vh}
      nav{display:flex;gap:1rem;padding:1rem 2rem;background:#1e293b;border-bottom:1px solid #334155;flex-wrap:wrap}
      nav a{color:#94a3b8;text-decoration:none;font-size:.9rem;padding:.25rem .5rem;border-radius:4px}
      nav a:hover{color:#f1f5f9;background:#334155}
      main{padding:2rem;max-width:1200px;margin:0 auto}
      h1{font-size:1.75rem;margin-bottom:1rem;color:#f1f5f9}
      h2{font-size:1.1rem;margin-bottom:.5rem;color:#cbd5e1}
      .card{background:#1e293b;border:1px solid #334155;border-radius:8px;padding:1.25rem;margin-bottom:1rem}
      .placeholder{color:#64748b;font-style:italic;font-size:.9rem}
    </style>
  </head>
  <body>
    <nav>
      <a href={base}>Overview</a>
      <a href={base + 'training'}>Training</a>
      <a href={base + 'recovery'}>Recovery</a>
      <a href={base + 'performance'}>Performance</a>
      <a href={base + 'plan'}>Plan</a>
      <a href={base + 'season'}>Season</a>
    </nav>
    <main><slot /></main>
  </body>
</html>
